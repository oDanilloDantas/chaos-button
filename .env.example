# Public, build-time variables. Next inlines NEXT_PUBLIC_* into the client
# bundle at build time, so set these where the build runs (locally in
# .env.local, or in the CI/Cloudflare build environment). They are not secrets.
#
# Copy to .env.local and fill in. .env.local is git-ignored.
#
# Runtime server secrets (e.g. N8N_CAPTURE_URL) do NOT go here — see .dev.vars.example.

# Google Tag Manager container id, e.g. GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Cloudflare Web Analytics beacon token (optional).
# Easiest path: enable Web Analytics in the Cloudflare dashboard, which
# auto-injects the beacon, and leave this empty.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Canonical site URL used for metadata and Open Graph.
NEXT_PUBLIC_SITE_URL=https://caos.andremariga.com.br
